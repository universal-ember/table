{
  "name": "docs-app",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation for the @universal-ember/table addon",
  "repository": "https://github.com/universal-ember/table",
  "license": "MIT",
  "author": "NullVoxPopuli",
  "scripts": {
    "build:test": "NODE_ENV=development vite build --mode test",
    "build:prod": "vite build",
    "lint:types": "glint",
    "start": "vite --port 4201",
    "test:ember": "pnpm build:test && pnpm dist:ember:test",
    "test:preview": "pnpm vite preview",
    "dist:ember:test": "ember test --path dist --config-file ./testem.cjs --test-port 0",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "_syncPnpm": "pnpm sync-dependencies-meta-injected"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@ember/optional-features": "^2.0.0",
    "@ember/test-helpers": "^5.1.0",
    "@embroider/compat": "alpha",
    "@embroider/config-meta-loader": "alpha",
    "@embroider/core": "alpha",
    "@embroider/util": "alpha",
    "@embroider/vite": "alpha",
    "@glimmer/component": "^2.0.0",
    "@glint/core": "unstable",
    "@glint/environment-ember-loose": "unstable",
    "@glint/environment-ember-template-imports": "unstable",
    "@glint/template": "unstable",
    "@html-next/vertical-collection": "^4.0.2",
    "@tailwindcss/typography": "^0.5.9",
    "@tsconfig/ember": "^3.0.9",
    "@types/dompurify": "^3.2.0",
    "@types/qunit": "^2.19.3",
    "@types/rsvp": "^4.0.4",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.1.2",
    "cssnano": "^7.0.6",
    "ember-cli": "~4.8.0",
    "ember-eslint": "^0.2.1",
    "ember-fetch": "^8.1.2",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.1",
    "ember-qunit": "^9.0.1",
    "ember-resolver": "^13.1.0",
    "ember-source": "~6.2.0",
    "ember-template-imports": "^4.3.0",
    "ember-template-lint": "^7.0.0",
    "eslint": "^9.21.0",
    "pnpm-sync-dependencies-meta-injected": "^0.0.14",
    "prettier": "^3.5.3",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "qunit": "^2.19.4",
    "qunit-dom": "^3.4.0",
    "typescript": "~5.8.2",
    "vite": "6.2.1"
  },
  "ember": {
    "edition": "octane"
  },
  "dependencies": {
    "@ember/test-waiters": "^4.0.0",
    "@embroider/router": "^2.0.0",
    "@shikijs/rehype": "^3.1.0",
    "@universal-ember/docs-support": "0.2.0",
    "@universal-ember/table": "workspace:*",
    "content-tag": "^3.0.0",
    "decorator-transforms": "^2.3.0",
    "dompurify": "^3.2.4",
    "ember-browser-services": "^5.0.1",
    "ember-cached-decorator-polyfill": "^1.0.1",
    "ember-focus-trap": "^1.1.0",
    "ember-mobile-menu": "^5.1.0",
    "ember-modifier": "^4.2.0",
    "ember-primitives": "0.27.2",
    "ember-repl": "^6.0.0",
    "ember-resources": "^7.0.2",
    "kolay": "^3.0.0",
    "reactiveweb": "^1.2.2",
    "shiki": "^3.1.0",
    "should-handle-link": "^1.2.2",
    "tracked-built-ins": "^4.0.0"
  },
  "dependenciesMeta": {
    "@universal-ember/table": {
      "injected": true
    }
  },
  "volta": {
    "extends": "../package.json"
  }
}
